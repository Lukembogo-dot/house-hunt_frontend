{
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "househuntkenya.co.ke"
        }
      ],
      "destination": "https://www.househuntkenya.co.ke/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://house-hunt-api-kemz.onrender.com/api/:path*"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://house-hunt-api-kemz.onrender.com/sitemap.xml"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(bot|crawler|spider|crawling|googlebot|bingbot|slurp|duckduckbot|baiduspider|yandexbot|facebookexternalhit|twitterbot|rogerbot|linkedinbot|embedly|slackbot|ia_archiver|whatsapp|pinterest|tumblr|flipboard|nuzzel|discordbot).*"
        }
      ],
      "destination": "https://service.prerender.io/https://www.househuntkenya.co.ke/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    }
  ]
}