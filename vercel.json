{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://house-hunt-api-kemz.onrender.com/api/:path*"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://house-hunt-api-kemz.onrender.com/sitemap.xml"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*?(googlebot|bingbot|yandex|baiduspider|twitterbot|facebookexternalhit|rogerbot|linkedinbot|embedly|slackbot|ia_archiver|whatsapp|pinterest).*?"
        }
      ],
      "destination": "https://service.prerender.io/https://www.househuntkenya.co.ke/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}